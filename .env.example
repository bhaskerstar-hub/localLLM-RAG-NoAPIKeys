# =====================================================================
# Enterprise RAG Platform - environment configuration
#
# Copy this file to `.env` and fill in the values you need.
# Defaults are chosen so the app works out-of-the-box with NO API keys
# (LLM_PROVIDER=ollama, EMBEDDING_PROVIDER=huggingface, Langfuse disabled).
# =====================================================================

# --- LLM Provider -----------------------------------------------------
# One of: anthropic | openai | ollama
LLM_PROVIDER=ollama

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Point this at any Ollama daemon you have running locally (default model: phi3:mini).
# Use http://localhost:11434 for local (non-Docker) dev,
# http://host.docker.internal:11434 when running inside docker compose.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# --- Embeddings ---------------------------------------------------------
# One of: huggingface | openai
# NOTE: Anthropic has no embeddings API, so this is independent of
# LLM_PROVIDER. Changing this after documents are ingested requires
# re-ingestion (different vector space).
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Chroma (embedded vector store) -------------------------------------
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rag_documents

# --- App database (SQLite: documents, chat history, feedback) -----------
DATABASE_URL=sqlite:///./data/app.db

# --- Retrieval / chunking -----------------------------------------------
RETRIEVER_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Langfuse (self-hosted observability) --------------------------------
ENABLE_LANGFUSE=false
# Use http://localhost:3300 for local (non-Docker) dev,
# http://langfuse-web:3000 when running inside docker compose.
LANGFUSE_HOST=http://localhost:3300
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Langfuse self-host secrets (docker compose only) --------------------
# Generate each with: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=CHANGEME
LANGFUSE_ENCRYPTION_KEY=CHANGEME
LANGFUSE_SALT=CHANGEME
LANGFUSE_POSTGRES_PASSWORD=CHANGEME
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGEME
LANGFUSE_REDIS_PASSWORD=CHANGEME
LANGFUSE_MINIO_ROOT_PASSWORD=CHANGEME

# Auto-provision an org/project/API keys on first boot so
# LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY above can be pre-seeded.
LANGFUSE_INIT_ORG_ID=rag-portfolio
LANGFUSE_INIT_ORG_NAME=RAG Portfolio
LANGFUSE_INIT_PROJECT_ID=rag-app
LANGFUSE_INIT_PROJECT_NAME=Enterprise RAG
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-CHANGEME
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_PASSWORD=
LANGFUSE_INIT_USER_NAME=Admin

# --- Optional: automated answer-quality scoring (RAGAS) -------------------
ENABLE_RAGAS_SCORING=false

# --- Frontend -------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8100
